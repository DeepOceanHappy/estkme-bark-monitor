# Copy this file to .env on your cloud server, then fill in BARK_KEY.
BARK_KEY=
BARK_SERVER=https://api.day.app
BARK_SOUND=glass

ESTKME_PRODUCT_API=https://api.estk.me/user/shop/products/1
ESTKME_PRODUCT_PAGE=https://store.estk.me/products/1
ESTKME_VARIANT_TITLE=ESTKme Max
ESTKME_INTERVAL_SECONDS=60
ESTKME_NOTIFY_ON_STARTUP_IF_AVAILABLE=true

# Keep the web UI private by default. Use SSH tunnel to open it locally.
ESTKME_HOST=127.0.0.1
ESTKME_PORT=8765
ESTKME_DATA_DIR=./data
